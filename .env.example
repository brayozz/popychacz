# Token bota Discord (Discord Developer Portal -> Twoja aplikacja -> Bot -> Reset/Copy Token)
DISCORD_TOKEN=your_discord_bot_token

# ID kanalu Discord, na ktory PatchBot wysyla wiadomosci
# (Discord: Ustawienia -> Zaawansowane -> tryb developera ON, potem PPM na kanale -> Kopiuj ID)
DISCORD_CHANNEL_ID=123456789012345678

# URL Incoming Webhooka Slacka (api.slack.com/apps -> Twoja apka -> Incoming Webhooks)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# (opcjonalnie) sciezka do pliku logu
BRIDGE_LOG_PATH=/var/log/patchbot-bridge/bridge.log
